{
  "name": "提示词体检系统",
  "version": "1.0",
  "description": "为提示词打分并提供改进建议",
  
  "checkup_dimensions": [
    {
      "name": "角色定义",
      "weight": 0.20,
      "check_items": [
        "是否明确定义了 AI 的角色/身份？",
        "角色是否与任务匹配？",
        "是否有专业领域定位？"
      ],
      "scoring": {
        "0": "完全没有角色定义",
        "5": "有简单角色定义",
        "10": "角色定义清晰且专业"
      }
    },
    {
      "name": "任务描述",
      "weight": 0.25,
      "check_items": [
        "任务目标是否清晰？",
        "是否有具体输出要求？",
        "是否有数量/质量要求？"
      ],
      "scoring": {
        "0": "任务模糊不清",
        "5": "任务基本明确",
        "10": "任务描述详细具体"
      }
    },
    {
      "name": "上下文信息",
      "weight": 0.15,
      "check_items": [
        "是否提供了背景信息？",
        "是否有目标受众说明？",
        "是否有使用场景描述？"
      ],
      "scoring": {
        "0": "无上下文",
        "5": "有基本背景",
        "10": "上下文完整详细"
      }
    },
    {
      "name": "输出格式",
      "weight": 0.20,
      "check_items": [
        "是否指定了输出格式？",
        "是否有结构要求？",
        "是否有字数/长度要求？"
      ],
      "scoring": {
        "0": "无格式要求",
        "5": "有简单格式",
        "10": "格式要求详细清晰"
      }
    },
    {
      "name": "示例 (Few-shot)",
      "weight": 0.10,
      "check_items": [
        "是否提供了示例？",
        "示例是否相关？",
        "示例数量是否足够？"
      ],
      "scoring": {
        "0": "无示例",
        "5": "有 1-2 个示例",
        "10": "有 3-5 个高质量示例"
      }
    },
    {
      "name": "边界条件",
      "weight": 0.10,
      "check_items": [
        "是否有禁止项说明？",
        "是否有注意事项？",
        "是否有错误处理？"
      ],
      "scoring": {
        "0": "无边界说明",
        "5": "有简单禁止项",
        "10": "边界条件完整"
      }
    }
  ],

  "score_levels": {
    "90-100": {
      "level": "🏆 完美提示词",
      "message": "你的提示词已经是专业级别，可以直接使用！"
    },
    "80-89": {
      "level": "✨ 优秀",
      "message": "提示词质量很高，微调即可达到完美！"
    },
    "70-79": {
      "level": "👍 良好",
      "message": "提示词不错，但有改进空间。"
    },
    "60-69": {
      "level": "⚠️ 及格",
      "message": "提示词基本可用，建议优化。"
    },
    "0-59": {
      "level": "🚑 需要重写",
      "message": "提示词问题较多，建议参考改进版本。"
    }
  },

  "common_issues": [
    {
      "issue": "缺少角色定义",
      "fix": "添加 <instructions> 标签，明确 AI 角色和专业领域",
      "example": "<instructions>你是一位专业文案策划专家...</instructions>"
    },
    {
      "issue": "任务描述模糊",
      "fix": "用具体数字和明确要求替换模糊描述",
      "example": "将'写个好标题'改为'生成 10 个 15 字以内的标题'"
    },
    {
      "issue": "无输出格式",
      "fix": "添加 <format> 标签，指定输出结构和格式",
      "example": "<format>使用表格格式，包含 3 列...</format>"
    },
    {
      "issue": "缺少示例",
      "fix": "添加 <examples> 标签，提供 2-3 个示例",
      "example": "<examples>示例 1:... 示例 2:...</examples>"
    },
    {
      "issue": "否定词滥用",
      "fix": "用肯定句表达期望，而非否定句",
      "example": "将'不要写太长'改为'保持简洁 (300 字以内)'"
    }
  ],

  "output_template": {
    "score": "总分 (0-100)",
    "level": "等级 (🏆/✨/👍/⚠️/🚑)",
    "dimension_scores": {
      "角色定义": "分数/20",
      "任务描述": "分数/25",
      "上下文": "分数/15",
      "输出格式": "分数/20",
      "示例": "分数/10",
      "边界条件": "分数/10"
    },
    "issues": ["问题 1", "问题 2", "问题 3"],
    "suggestions": ["建议 1", "建议 2", "建议 3"],
    "improved_prompt": "改进后的完整提示词"
  }
}
